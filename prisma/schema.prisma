// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  // Static fallback URL for schema validation only.
  // The actual database connection is handled by the adapter in src/lib/db.ts
  // which reads DATABASE_URL at runtime (works on Vercel + Turso).
  url = "file:./prisma/dev.db"
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         String    @default("ADMIN") // ADMIN | CUSTOMER
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  wishlistItems WishlistItem[]
  orders        Order[]
}

// Order.userId -> User relation needed (added to Order model below)

// ─── CATEGORIES ──────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  icon        String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
}

// ─── PRODUCTS (RAKHI CATALOG) ────────────────────────────────────────────────

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  category         String   // category name (string)
  categoryId       String?
  price            Int      // in INR (paise not used; whole rupees)
  compareAtPrice   Int?     // original price for discount display
  images           String   // JSON array of image URLs
  primaryImage     String
  shortDescription String
  description      String
  materials        String   // JSON array
  features         String   // JSON array
  sku              String   @unique
  badge            String?  // e.g. "New", "Bestseller", "Limited"
  inStock          Int      @default(50)
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  rating           Float    @default(5.0)
  reviewCount      Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  categoryRef   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wishlistItems WishlistItem[]
  orderItems    OrderItem[]
}

// ─── ORDERS (WHATSAPP-BASED) ─────────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String?
  customerName  String
  customerPhone String
  customerEmail String?
  customerAddress String?
  customerCity  String?
  customerState String?
  customerPincode String?
  customerNotes String?
  items         OrderItem[]
  subtotal      Int
  shipping      Int         @default(0)
  total         Int
  status        String      @default("PENDING") // PENDING | CONFIRMED | SHIPPED | DELIVERED | CANCELLED
  whatsappSentAt DateTime?
  adminNotes    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String?
  name      String
  image     String
  price     Int
  quantity  Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

// ─── WISHLIST ────────────────────────────────────────────────────────────────

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ─── SITE SETTINGS (ADMIN-EDITABLE) ──────────────────────────────────────────

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String // JSON-encoded value
}

// ─── HERO SLIDES (ADMIN-EDITABLE) ────────────────────────────────────────────

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String
  description String?
  image       String
  ctaLabel    String?
  ctaLink     String?
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── SITE CONTENT (ABOUT, STORY, ETC.) ───────────────────────────────────────

model SiteContent {
  id        String   @id @default(cuid())
  section   String   @unique // "about" | "story" | "care" | "shipping" | "contact" | "announcement"
  data      String   // JSON
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
